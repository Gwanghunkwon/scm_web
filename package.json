{
  "name": "scm-mvp",
  "private": true,
  "description": "SCM 백엔드(FastAPI) + 프론트(Next.js) 동시 실행",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd backend && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
